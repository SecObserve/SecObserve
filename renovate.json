{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "baseBranchPatterns": [
        "dev"
    ],
    "dependencyDashboard": true,
    "dependencyDashboardApproval": false,
    "labels": [
        "dependencies"
    ],
    "lockFileMaintenance": {
        "enabled": true
    },
    "rebaseWhen": "conflicted",
    "pip_requirements": {
        "managerFilePatterns": [
            "/mkdocs_requirements.txt/",
            "/backend/poetry_requirements.txt/"
        ]
    },
    "packageRules": [
        {
            "matchPackageNames": [
                "python"
            ],
            "allowedVersions": "<3.15"
        },
        {
            "matchPackageNames": [
                "django"
            ],
            "allowedVersions": "<6.1"
        },
        {
            "matchPackageNames": [
                "node"
            ],
            "allowedVersions": "<25"
        },
        {
            "matchPackageNames": [
                "postgres"
            ],
            "allowedVersions": "<16"
        },
        {
            "matchPackageNames": [
                "mysql"
            ],
            "allowedVersions": "<9"
        }
    ]
}
